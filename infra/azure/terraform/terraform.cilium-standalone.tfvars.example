subscription_id     = ""
location            = "eastus2"
resource_group_name = "rg-calico-hep-lab"
name_prefix         = "hep-lab"

admin_cidr             = "203.0.113.10/32"
ssh_public_key_path    = "/home/ubuntu/.ssh/id_ed25519.pub"
admin_username         = "azureuser"
windows_admin_username = "azureuser"
windows_admin_password = "SetARealAzurePassword123!"

k3s_vm_size            = "Standard_B2s"
cilium_linux_vm_size   = "Standard_B2s"
cilium_windows_vm_size = "Standard_B2s"

k3s_agent_count = 2
legacy_vm_count = 0

cluster2_enabled     = false
cluster2_agent_count = 2

# This standalone-host round intentionally pins the lab to the older toolchain
# needed for the deprecated Linux external-workload path.
k3s_version        = "v1.30.8+k3s1"
cilium_version     = "1.17.6"
cilium_cli_version = "v0.16.24"

cilium_linux_vm_enabled   = true
cilium_windows_vm_enabled = true

cluster_cidr          = "10.42.0.0/16"
service_cidr          = "10.43.0.0/16"
cluster2_cluster_cidr = "10.52.0.0/16"
cluster2_service_cidr = "10.53.0.0/16"
